From f80b61d6c8d6de0ce80c29052590c359a7f4b465 Mon Sep 17 00:00:00 2001
From: Lukas Oberhuber <lukas@hiphops.io>
Date: Mon, 18 May 2026 22:33:50 +0100
Subject: [PATCH] macos: Fix #8213

Revert "quartz: gtkwindow-quartz - fix windows fighting focus"

This reverts commit 8c0ef808eadeac0773ccf750fce37dd71422e60b as the fix
was superceeded by !9322.

https://gitlab.gnome.org/GNOME/gtk/-/work_items/8213

Part-of: <https://gitlab.gnome.org/GNOME/gtk/-/merge_requests/9951>
---
 gdk/quartz/gdkwindow-quartz.c | 11 ++---------
 1 file changed, 2 insertions(+), 9 deletions(-)

diff --git a/gdk/quartz/gdkwindow-quartz.c b/gdk/quartz/gdkwindow-quartz.c
index 1405a93c22..672103f7bd 100644
--- a/gdk/quartz/gdkwindow-quartz.c
+++ b/gdk/quartz/gdkwindow-quartz.c
@@ -1164,15 +1164,8 @@ gdk_window_quartz_show (GdkWindow *window, gboolean already_mapped)
       make_key = (window->accept_focus && focus_on_map &&
                   window->window_type != GDK_WINDOW_TEMP);
 
-      /* If window is already mapped and visible, skip showAndMakeKey to avoid
-       * spurious resignMain/becomeMain notifications that cause focus fighting.
-       * See https://gitlab.gnome.org/GNOME/gimp/-/issues/14901
-       */
-      if (!GDK_WINDOW_IS_MAPPED (window) || ![impl->toplevel isVisible])
-        {
-          [(GdkQuartzNSWindow*)impl->toplevel showAndMakeKey:make_key];
-          clear_toplevel_order ();
-        }
+      [(GdkQuartzNSWindow*)impl->toplevel showAndMakeKey:make_key];
+      clear_toplevel_order ();
 
       _gdk_quartz_events_send_map_event (window);
     }
